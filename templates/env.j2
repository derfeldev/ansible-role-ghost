# Ghost Configuration
url={{ ghost_url }}
NODE_ENV={{ ghost_node_env }}
{% if ghost_admin_url %}
admin__url={{ ghost_admin_url }}
{% endif %}

# Database Configuration
database__client=mysql
database__connection__host={{ ghost_database_hostname }}
database__connection__port={{ ghost_database_port }}
database__connection__user={{ ghost_database_username }}
database__connection__password={{ ghost_database_password }}
database__connection__database={{ ghost_database_name }}
database__pool__min={{ ghost_database_pool_min }}
database__pool__max={{ ghost_database_pool_max }}

# Mail Configuration
{% if ghost_mail_enabled | bool %}
mail__transport={{ ghost_mail_transport }}
{% if ghost_mail_options_service %}
mail__options__service={{ ghost_mail_options_service }}
{% else %}
mail__options__host={{ ghost_mail_options_host }}
mail__options__port={{ ghost_mail_options_port }}
mail__options__secure={{ ghost_mail_options_secure | to_json }}
{% endif %}
mail__options__auth__user={{ ghost_mail_options_auth_user }}
mail__options__auth__pass={{ ghost_mail_options_auth_pass }}
mail__from={{ ghost_mail_from }}
mail__from_name={{ ghost_mail_from_name }}
{% endif %}

# Storage Configuration
{% if ghost_storage_active %}
storage__active={{ ghost_storage_active }}
{% endif %}
{% if ghost_storage_media %}
storage__media={{ ghost_storage_media }}
{% endif %}
{% if ghost_storage_files %}
storage__files={{ ghost_storage_files }}
{% endif %}

# Logging Configuration
logging__level={{ ghost_logging_level }}
logging__transports={{ ghost_logging_transports | to_json }}
logging__useLocalTime={{ ghost_logging_use_local_time | to_json }}
logging__rotation__enabled={{ ghost_logging_rotation_enabled | to_json }}
logging__rotation__period={{ ghost_logging_rotation_period }}
logging__rotation__count={{ ghost_logging_rotation_count }}

# Cache Configuration
{% if ghost_cache_redis_enabled | bool %}
adapters__cache__active=Redis
adapters__cache__Redis__host={{ ghost_cache_redis_host }}
adapters__cache__Redis__port={{ ghost_cache_redis_port }}
{% if ghost_cache_redis_username %}
adapters__cache__Redis__username={{ ghost_cache_redis_username }}
{% endif %}
{% if ghost_cache_redis_password %}
adapters__cache__Redis__password={{ ghost_cache_redis_password }}
{% endif %}
{% if ghost_cache_redis_ttl %}
adapters__cache__Redis__ttl={{ ghost_cache_redis_ttl }}
{% endif %}
adapters__cache__Redis__keyPrefix={{ ghost_cache_redis_key_prefix }}
{% endif %}

# Image Optimization
imageOptimization__resize={{ ghost_image_optimization_resize_enabled | to_json }}
imageOptimization__srcsets={{ ghost_image_optimization_srcsets_enabled | to_json }}

# Miscellaneous
compress={{ ghost_compress_enabled | to_json }}
privacy={{ ghost_privacy_enabled | to_json }}
security__staffDeviceVerification={{ ghost_security_staff_device_verification_enabled | to_json }}

# Self-hosted front-end scripts
{% if ghost_portal_url %}
portal__url={{ ghost_portal_url }}
{% endif %}
{% if ghost_comments_url %}
comments__url={{ ghost_comments_url }}
{% endif %}
{% if ghost_comments_styles %}
comments__styles={{ ghost_comments_styles }}
{% endif %}
{% if ghost_sodo_search_url %}
sodoSearch__url={{ ghost_sodo_search_url }}
{% endif %}
{% if ghost_sodo_search_styles %}
sodoSearch__styles={{ ghost_sodo_search_styles }}
{% endif %}

{{ ghost_environment_variables_additional_variables }}
